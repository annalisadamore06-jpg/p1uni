# P1UNI Secrets template
# Copia questo file come `.env` e inserisci i tuoi valori
# Il file .env e' nel .gitignore, NON deve essere committato

# Databento API key (single key for Live + Historical)
DATABENTO_API_KEY=db-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# GexBot Quant API key
GEXBOT_API_KEY=XXXXXXXXXXXX

# NinjaTrader 8 credentials
NT8_USER=YOUR_USERNAME
NT8_PASSWORD=YOUR_PASSWORD

# Telegram bot (per alerts)
TELEGRAM_BOT_TOKEN=123456789:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TELEGRAM_CHAT_ID=123456789
